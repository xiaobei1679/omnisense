# OmniSense 可选外部模型配置（全部可选）
# 框架网关（openclaw）已覆盖文本推理，无需任何 key。
# 仅当你需要「看图视觉(VLM) / 语音听写(ASR) / 出声(TTS)」时才填写以下任意一项。
# 复制本文件为 .env 后填写；留空则对应能力诚实降级。

# —— 文本/多模态大模型（OpenAI 兼容，builtin 网关不可用时的回退）——
LLM_BASE_URL=https://api.your-llm.com/v1
LLM_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# —— 视觉理解（看图）——
VLM_BASE_URL=
VLM_KEY=
VLM_MODEL=

# —— 语音转写（听）——
ASR_BASE_URL=
ASR_KEY=
ASR_MODEL=whisper-1

# —— 语音合成（出声）——
TTS_BASE_URL=
TTS_KEY=
TTS_MODEL=tts-1
